{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["name", "version"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Skill name"
    },
    "version": {
      "type": "string",
      "description": "Skill version"
    },
    "description": {
      "type": "string",
      "description": "Skill description"
    },
    "install": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["shell", "script", "none"],
          "default": "shell"
        },
        "command": {
          "type": "string",
          "description": "Installation command to execute"
        },
        "workingDir": {
          "type": "string",
          "default": ".",
          "description": "Working directory relative to skill root"
        },
        "env": {
          "type": "object",
          "default": {},
          "description": "Environment variables for installation"
        }
      }
    },
    "validate": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["shell", "script", "none"],
          "default": "shell"
        },
        "command": {
          "type": "string",
          "description": "Validation command to execute"
        },
        "workingDir": {
          "type": "string",
          "default": ".",
          "description": "Working directory relative to skill root"
        },
        "timeoutSeconds": {
          "type": "integer",
          "default": 300,
          "minimum": 1,
          "description": "Timeout for validation command"
        }
      }
    },
    "openclawIntegration": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["skill", "plugin", "tool"],
          "description": "Type of OpenClaw integration"
        },
        "configSnippetFile": {
          "type": "string",
          "description": "Path to config snippet file"
        },
        "autoEnable": {
          "type": "boolean",
          "default": false,
          "description": "Whether to auto-enable after installation"
        }
      }
    },
    "requirements": {
      "type": "object",
      "properties": {
        "nodeVersion": {
          "type": "string",
          "description": "Required Node.js version (semver)"
        },
        "os": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["linux", "darwin", "win32"]
          },
          "description": "Supported operating systems"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Required external dependencies"
        }
      }
    }
  }
}
