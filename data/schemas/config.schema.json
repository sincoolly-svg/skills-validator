{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["sources", "storage"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["repo-dir", "local-dir"]
          },
          "name": {
            "type": "string",
            "description": "Source name for identification"
          },
          "repo": {
            "type": "string",
            "format": "uri",
            "description": "GitHub repository URL (for repo-dir type)"
          },
          "skillsRoot": {
            "type": "string",
            "description": "Root directory containing skills (for repo-dir type)"
          },
          "branch": {
            "type": "string",
            "default": "main",
            "description": "Git branch to clone"
          },
          "path": {
            "type": "string",
            "description": "Local directory path (for local-dir type)"
          }
        }
      }
    },
    "schedule": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "times": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^\\d{2}:\\d{2}$"
          },
          "description": "Array of times in HH:MM format"
        },
        "timezone": {
          "type": "string",
          "default": "UTC"
        }
      }
    },
    "storage": {
      "type": "object",
      "required": ["baseDir"],
      "properties": {
        "baseDir": {
          "type": "string",
          "description": "Base directory for all validator data"
        },
        "skillsIndexFile": {
          "type": "string",
          "default": "skills-index.json"
        },
        "reportsDir": {
          "type": "string",
          "default": "reports"
        },
        "logsDir": {
          "type": "string",
          "default": "logs"
        },
        "tempDir": {
          "type": "string",
          "default": "temp"
        },
        "cacheDir": {
          "type": "string",
          "default": "cache"
        }
      }
    },
    "execution": {
      "type": "object",
      "properties": {
        "maxParallelValidations": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "default": 2
        },
        "timeoutPerSkillMinutes": {
          "type": "integer",
          "minimum": 5,
          "default": 30
        },
        "gitCloneDepth": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        }
      }
    },
    "notification": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "onNewSkill": {
          "type": "boolean",
          "default": false
        },
        "onValidationComplete": {
          "type": "boolean",
          "default": true
        },
        "channels": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    }
  }
}
